# EditorConfig helps maintain consistent coding styles
# across different editors and IDEs - https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# TypeScript and JavaScript
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2
quote_type = single

# JSON files
[*.json]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.{md,mdx}]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# CSS, SCSS, and similar
[*.{css,scss,sass,less}]
indent_style = space
indent_size = 2

# HTML files
[*.{html,htm}]
indent_style = space
indent_size = 2

# XML files
[*.{xml,svg}]
indent_style = space
indent_size = 2

# Configuration files
[*.{toml,ini}]
indent_style = space
indent_size = 2

# Docker files
[{Dockerfile,*.dockerfile}]
indent_style = space
indent_size = 2

# Shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 2

# Python files (for scripts)
[*.py]
indent_style = space
indent_size = 4

# Makefiles (require tabs)
[{Makefile,makefile,*.mk}]
indent_style = tab
indent_size = 4

# Go files (if any)
[*.go]
indent_style = tab
indent_size = 4

# Package files
[{package.json,package-lock.json,yarn.lock}]
indent_style = space
indent_size = 2
# CaboFitPass Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# REQUIRED: Core Application Settings
# =============================================================================

# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Application URLs (Required)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=CaboFitPass
NEXT_PUBLIC_SUPPORT_EMAIL=support@cabofitpass.com

# =============================================================================
# OPTIONAL: Payment Processing
# =============================================================================

# Stripe Configuration (for payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# =============================================================================
# OPTIONAL: Third-party Services
# =============================================================================

# Email Service (Resend)
RESEND_API_KEY=re_your_resend_api_key

# File Uploads (UploadThing)
UPLOADTHING_SECRET=sk_live_your_uploadthing_secret
UPLOADTHING_APP_ID=your_uploadthing_app_id

# Google Services
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# =============================================================================
# OPTIONAL: AI Services
# =============================================================================

# OpenAI API (for AI features)
OPENAI_API_KEY=sk-your_openai_api_key

# Anthropic API (for Claude AI features)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# =============================================================================
# OPTIONAL: Monitoring and Analytics
# =============================================================================

# Sentry (Error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=cabo-fit-pass

# PostHog (Analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# LogRocket (Session replay)
NEXT_PUBLIC_LOGROCKET_ID=your_logrocket_app_id

# =============================================================================
# OPTIONAL: Development and Testing
# =============================================================================

# Database (for local development)
DATABASE_URL=postgresql://postgres:password@localhost:5432/cabofitpass

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# Node Environment
NODE_ENV=development

# =============================================================================
# OPTIONAL: Social Login Providers
# =============================================================================

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret

# Apple OAuth
APPLE_CLIENT_ID=your.apple.bundle.id
APPLE_CLIENT_SECRET=your_apple_client_secret

# =============================================================================
# OPTIONAL: Communication Services
# =============================================================================

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=AC_your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (Alternative email service)
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# =============================================================================
# OPTIONAL: External APIs
# =============================================================================

# Weather API (for outdoor classes)
WEATHER_API_KEY=your_weather_api_key

# Currency Exchange API
EXCHANGE_RATES_API_KEY=your_exchange_rates_api_key

# =============================================================================
# OPTIONAL: Feature Flags
# =============================================================================

# Enable/disable specific features
ENABLE_PAYMENTS=true
ENABLE_NOTIFICATIONS=true
ENABLE_AI_FEATURES=false
ENABLE_SOCIAL_LOGIN=true
ENABLE_ANALYTICS=true

# =============================================================================
# DEPLOYMENT SPECIFIC
# =============================================================================

# Vercel (automatically set in Vercel deployments)
VERCEL_URL=your-app.vercel.app

# Custom domain
NEXT_PUBLIC_DOMAIN=cabofitpass.com

# =============================================================================
# SECURITY
# =============================================================================

# JWT Secret (for custom auth)
JWT_SECRET=your_super_secret_jwt_key_here

# Encryption key (for sensitive data)
ENCRYPTION_KEY=your_32_character_encryption_key

# CSRF Secret
CSRF_SECRET=your_csrf_secret_key

# =============================================================================
# BACKUP AND STORAGE
# =============================================================================

# AWS S3 (for file storage and backups)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=cabofitpass-storage
AWS_REGION=us-west-2

# =============================================================================
# NOTIFICATIONS
# =============================================================================

# Slack (for internal notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# Discord (for community notifications)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# =============================================================================
# BUSINESS SETTINGS
# =============================================================================

# Los Cabos specific settings
DEFAULT_TIMEZONE=America/Mazatlan
DEFAULT_CURRENCY=MXN
DEFAULT_LOCALE=es-MX

# Business hours
BUSINESS_HOURS_START=06:00
BUSINESS_HOURS_END=22:00

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================

# Bundle analyzer
ANALYZE=false

# Disable telemetry
NEXT_TELEMETRY_DISABLED=1

# Debug mode
DEBUG=false

# =============================================================================
# NOTES
# =============================================================================

# 1. Never commit .env files to version control
# 2. Use different values for development, staging, and production
# 3. Store production secrets securely (Vercel, AWS Secrets Manager, etc.)
# 4. Regularly rotate API keys and secrets
# 5. Use environment-specific prefixes for organization
# 6. Document any custom environment variables in this file
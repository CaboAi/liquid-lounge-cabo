# API Configuration
API_URL=http://localhost:3000/api
API_TIMEOUT=30000

# Development URLs (for local development)
# Use your computer's IP address when testing on physical device
# API_URL=http://192.168.1.100:3000/api

# Production URLs (for production builds)
# API_URL=https://api.bailout.app/api

# Feature Flags
ENABLE_VOICE_ACTIVATION=true
ENABLE_LOCATION_TRACKING=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ONBOARDING=true
ENABLE_BIOMETRIC_AUTH=false

# Third-party Services (remove from mobile - handled by backend)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# App Configuration
APP_NAME=BailOut
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1
ENVIRONMENT=development

# Debugging
DEBUG_MODE=true
ENABLE_FLIPPER=true

# Analytics & Monitoring
ENABLE_ANALYTICS=false
ANALYTICS_API_KEY=your-analytics-api-key

# Expo Configuration (if using Expo)
EXPO_PROJECT_ID=your-expo-project-id
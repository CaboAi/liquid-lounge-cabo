{
  "name": "voice-generator",
  "model": "claude-sonnet-4-20250514",
  "temperature": 0.4,
  "max_tokens": 1500,
  "description": "Generates realistic AI voice content for bailout calls",
  "version": "1.0.0",
  "tools": [
    {
      "name": "elevenlabs_synthesizer",
      "type": "function",
      "description": "Generates voice audio using ElevenLabs API",
      "timeout": 15000
    },
    {
      "name": "playht_synthesizer",
      "type": "function",
      "description": "Alternative voice synthesis using PlayHT API",
      "timeout": 12000
    },
    {
      "name": "script_processor",
      "type": "function",
      "description": "Processes and adapts scenario scripts",
      "timeout": 2000
    },
    {
      "name": "voice_validator",
      "type": "function",
      "description": "Validates audio quality and characteristics",
      "timeout": 3000
    },
    {
      "name": "cache_manager",
      "type": "function",
      "description": "Manages voice clip caching and retrieval",
      "timeout": 1000
    }
  ],
  "triggers": [
    {
      "source": "call-orchestrator",
      "event": "voice_generation_request",
      "priority": "high"
    },
    {
      "source": "pre_generation_service",
      "event": "cache_warming_request",
      "priority": "low"
    },
    {
      "source": "quality_service",
      "event": "quality_validation_request",
      "priority": "medium"
    }
  ],
  "dependencies": [
    {
      "service": "elevenlabs_api",
      "required": true,
      "timeout": 15000,
      "fallback": "playht_api"
    },
    {
      "service": "playht_api",
      "required": false,
      "timeout": 12000,
      "fallback": "prerecorded_clips"
    },
    {
      "service": "audio_storage",
      "required": true,
      "timeout": 5000
    },
    {
      "service": "cdn_service",
      "required": false,
      "timeout": 3000
    }
  ],
  "voice_providers": {
    "primary": {
      "name": "elevenlabs",
      "api_version": "v1",
      "models": [
        "eleven_monolingual_v1",
        "eleven_multilingual_v1",
        "eleven_turbo_v2"
      ],
      "rate_limits": {
        "requests_per_minute": 60,
        "characters_per_month": 50000
      }
    },
    "fallback": {
      "name": "playht",
      "api_version": "v2",
      "models": [
        "PlayHT2.0-turbo",
        "Play3.0-mini"
      ],
      "rate_limits": {
        "requests_per_minute": 30,
        "characters_per_month": 25000
      }
    }
  },
  "voice_personas": {
    "mom": {

{
  "name": "bailout",
  "version": "1.0.0",
  "private": true,
  "description": "BailOut - AI-powered voice and text bail-out agent",
  "author": "CaboAi",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "pnpm --filter @bailout/mobile dev",
    "dev:backend": "pnpm --filter @bailout/backend dev",
    "dev": "pnpm run dev:backend & pnpm run dev:mobile",
    "build:mobile": "pnpm --filter @bailout/mobile build",
    "build:backend": "pnpm --filter @bailout/backend build",
    "build": "pnpm run build:backend && pnpm run build:mobile",
    "test": "pnpm -r test",
    "test:mobile": "pnpm --filter @bailout/mobile test",
    "test:backend": "pnpm --filter @bailout/backend test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "clean": "pnpm -r clean && rimraf node_modules",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.0",
    "@commitlint/config-conventional": "^18.6.0",
    "husky": "^9.0.11",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.4"
}